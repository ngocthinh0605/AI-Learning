# Copy this file to .env and fill in values before running docker-compose

# Database
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password

# JWT Secret — generate with:
#   ruby -e "require 'securerandom'; puts SecureRandom.hex(64)"
DEVISE_JWT_SECRET_KEY=your_super_secret_jwt_key_here

# Ollama — runs on your host machine (not in Docker)
# After installing Ollama: ollama pull gemma2:9b
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:9b
OLLAMA_MODEL_LARGE=gemma3:27b
# RAG: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSIONS=768

# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower & more RAM
WHISPER_MODEL=base

# Allowed frontend origin(s) for Rails CORS. Comma-separate when needed.
# Example: FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:3000
