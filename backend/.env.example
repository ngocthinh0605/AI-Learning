# Copy this file to .env and fill in values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# JWT Secret — generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(64)"
DEVISE_JWT_SECRET_KEY=your_super_secret_jwt_key_here

# AI Services
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:9b
# Second model for sidebar switcher (e.g. larger Gemma); pull the matching tag in Ollama
OLLAMA_MODEL_LARGE=gemma3:27b
# RAG embeddings (Ollama: pull nomic-embed-text)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSIONS=768
WHISPER_SERVICE_URL=http://localhost:8001

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3000

# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5
